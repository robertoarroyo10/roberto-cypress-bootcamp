    "cy:login": "npx cypress run --spec 'cypress/e2e/tests/features/**/*.feature' --env tags='@login'",
    "cy:smoke": "npx cypress run --spec 'cypress/e2e/tests/features/**/*.feature' --env tags='@smoke'",
    "cy:api": "npx cypress run --spec 'cypress/e2e/tests/apiTests/**/*.cy.js'",
